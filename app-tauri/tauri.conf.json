{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "prompt-launcher",
  "version": "0.1.0",
  "identifier": "com.shidil.prompt-launcher",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay",
        "title": "prompt-launcher",
        "width": 600,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "resizable": false,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns"]
  }
}
