        "fontSize": {
          "value": 11,
          "unit": "px"
        },
        "fontWeight": 500
      }
    },
    "tag": {
      "$type": "typography",
      "$value": {
        "fontFamily": "-apple-system, SF Pro Text, Inter, sans-serif",
        "fontSize": {
          "value": 10.5,
          "unit": "px"
        },
        "fontWeight": 500,
        "letterSpacing": {
          "value": 0.01,
          "unit": "em"
        }
      }
    },
    "brand": {
      "$type": "typography",
      "$value": {
        "fontFamily": "-apple-system, SF Pro Text, Inter, sans-serif",
        "fontSize": {
          "value": 11,
          "unit": "px"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0.04,
          "unit": "em"
        }
      }
    }
