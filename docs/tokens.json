    "sm": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 14,
        "unit": "px"
      }
    },
    "xxl": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "xxxl": {
      "$value": {
        "value": 18,
        "unit": "px"
      }
    },
    "xxxxl": {
      "$value": {
        "value": 22,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 7,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 14,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "-apple-system, SF Pro Display, Inter, sans-serif",
        "fontSize": {
          "value": 15,
          "unit": "px"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.01,
          "unit": "em"
        }
      }
    },
    "input": {
      "$type": "typography",
      "$value": {
        "fontFamily": "-apple-system, SF Pro Text, Inter, sans-serif",
        "fontSize": {
          "value": 19,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": -0.005,
          "unit": "em"
        }
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "-apple-system, SF Pro Text, Inter, sans-serif",
        "fontSize": {
          "value": 14,
          "unit": "px"
        },
        "fontWeight": 500,
        "letterSpacing": {
          "value": -0.005,
          "unit": "em"
        }
      }
    },
    "meta": {
