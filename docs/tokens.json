{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Spotlight-style overlay for a personal prompt library. Calm, dense, keyboard-first; macOS-vibrancy aesthetic.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.239,
          0.435,
          0.91
        ],
        "hex": "#3d6fe8"
      }
    },
    "primary-strong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.184,
          0.357,
          0.816
        ],
        "hex": "#2f5bd0"
      }
    },
    "primary-on": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "primary-tint": {
      "$value": {
        "colorSpace": "srgb",
